"use client";

import Link from "next/link";
import { useRouter } from "next/navigation";
import {
  Bell,
  Bot,
  ChevronDown,
  Home,
  LayoutDashboard,
  LogOut,
  Menu,
  Search,
  Settings,
  User,
  UserCircle,
} from "lucide-react";
import { Button } from "@/shared/components/ui/button";
import { NotificationBell } from "@/features/notifications/components/notification-bell";
import { ThemeModeToggle } from "@/shared/components/theme/theme-mode-toggle";
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuLabel,
  DropdownMenuSeparator,
  DropdownMenuTrigger,
} from "@/shared/components/ui/dropdown-menu";
import { useAuthStore } from "@/shared/store/auth-store";
import { authApi } from "@/services/auth/auth-api";
import { useWorkspaceBase } from "@/shared/hooks/use-workspace-base";
import {
  getRoleWorkspaceLabel,
  getWorkspaceHref,
} from "@/shared/lib/role-routing";
import { cn } from "@/shared/lib/utils";

export function Topbar({
  onMobileMenuToggle,
  title,
}: {
  onMobileMenuToggle: () => void;
  title?: string;
}) {
  const router = useRouter();
  const workspaceBase = useWorkspaceBase();
  const role = useAuthStore((state) => state.role);
  const user = useAuthStore((state) => state.user);
  const logout = useAuthStore((state) => state.logout);
  const workspaceLabel = getRoleWorkspaceLabel(role);
  const displayName = user?.name || "Career Pilot User";
  const initials = displayName
    .split(" ")
    .map((part) => part[0])
    .join("")
    .slice(0, 2)
    .toUpperCase();

  const handleLogout = async () => {
    try {
      await authApi.logout();
    } finally {
      logout();
      router.replace("/login");
    }
  };

  return (
    <header className="dark-surface-topbar z-30 shrink-0 border-b border-border/50 bg-card/95 px-3 py-3 shadow-sm shadow-elevation/5 backdrop-blur-xl sm:px-5 lg:px-7 dark:border-border/70">
      <div className="flex min-w-0 items-center justify-between gap-4">
        <div className="flex min-w-0 flex-1 items-center gap-3 sm:gap-4">
          <Button
            variant="ghost"
            size="icon"
            onClick={onMobileMenuToggle}
            className="h-10 w-10 shrink-0 border border-border/60 bg-background/50 text-foreground transition-all hover:border-border hover:bg-muted/40 md:hidden"
            aria-label="Open navigation menu"
          >
            <Menu className="h-5 w-5" />
          </Button>

          <div className="min-w-0 sm:w-56 md:w-72 lg:w-80">
            <div className="flex min-w-0 items-center gap-3">
              <div className="relative flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-primary text-[11px] font-bold text-primary-foreground shadow-lg shadow-primary/20 transition-transform hover:scale-105">
                CP
                <div className="absolute -bottom-1 -right-1 h-3 w-3 rounded-full border border-background/80 bg-accent shadow-sm" />
              </div>
              <div className="min-w-0">
                <p className="truncate text-xs font-semibold uppercase tracking-[0.15em] text-muted-foreground/70">
                  {workspaceLabel}
                </p>
                <h2 className="truncate text-sm font-semibold text-foreground sm:text-base">
                  {title || "Dashboard"}
                </h2>
              </div>
            </div>
          </div>

          <Link
            href={getWorkspaceHref(workspaceBase, "chat")}
            className="relative hidden min-w-0 max-w-md flex-1 rounded-lg border border-border/50 bg-background/40 px-3.5 py-2.5 pl-10 text-sm text-muted-foreground transition-all hover:border-primary/50 hover:bg-background/60 hover:text-foreground focus:border-primary/50 focus:outline-none focus:ring-2 focus:ring-primary/20 xl:block group"
          >
            <span className="hidden group-hover:inline">Chat with AI - Resumes, interviews, skills</span>
            <span className="inline group-hover:hidden">Open AI copilot</span>
            <Search className="absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground/70 transition-colors group-hover:text-muted-foreground" />
          </Link>
        </div>

        <div className="flex shrink-0 items-center gap-2.5 sm:gap-3">
          <Button
            asChild
            variant="outline"
            size="sm"
            className="hidden border-border/50 bg-background/50 text-muted-foreground transition-all hover:border-border/80 hover:bg-muted/40 hover:text-foreground lg:inline-flex"
          >
            <Link href="/">
              <Home className="h-4 w-4" />
              <span className="hidden xl:inline">Public Site</span>
            </Link>
          </Button>

          <Button
            asChild
            variant="ghost"
            size="sm"
            className="hidden border border-accent/30 bg-accent/10 text-accent transition-all hover:border-accent/50 hover:bg-accent/15 hover:text-accent lg:inline-flex gap-2"
          >
            <Link href={getWorkspaceHref(workspaceBase, "chat")}>
              <Bot className="h-4 w-4" />
              <span className="hidden xl:inline font-semibold">AI Copilot</span>
            </Link>
          </Button>

          <NotificationBell />

          <DropdownMenu>
            <DropdownMenuTrigger asChild>
              <Button
                variant="ghost"
                className={cn(
                  "h-10 rounded-lg border border-border/60 bg-background/60 px-2 text-foreground transition-all hover:border-border/80 hover:bg-muted/50",
                  "sm:h-11 sm:pl-2 sm:pr-3"
                )}
                aria-label="Open account menu"
              >
                <span className="relative flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-primary text-xs font-bold text-primary-foreground shadow-lg shadow-primary/20">
                  {initials || <User className="h-4 w-4" />}
                </span>
                <span className="hidden min-w-0 text-left sm:block ml-2">
                  <span className="block max-w-32 truncate text-sm font-semibold leading-4">
                    {displayName}
                  </span>
                  <span className="block max-w-32 truncate text-[11px] font-medium leading-4 text-muted-foreground">
                    {role === "ADMIN" ? "Admin" : role === "MENTOR" || role === "COACH" ? "Mentor" : "Professional"}
                  </span>
                </span>
                <ChevronDown className="hidden h-4 w-4 text-muted-foreground/60 sm:block ml-1" />
              </Button>
            </DropdownMenuTrigger>
            <DropdownMenuContent
              align="end"
              className="w-80 rounded-xl border-border/60 bg-popover p-2 text-popover-foreground shadow-xl shadow-elevation/10 backdrop-blur-xl"
            >
              <DropdownMenuLabel className="mb-2 rounded-lg bg-muted/35 p-4">
                <div className="flex min-w-0 items-center gap-3">
                  <span className="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-primary text-sm font-bold text-primary-foreground shadow-lg shadow-primary/20">
                    {initials || "U"}
                  </span>
                  <div className="min-w-0">
                    <p className="truncate text-sm font-semibold">{displayName}</p>
                    <p className="truncate text-xs font-normal text-muted-foreground/80">
                      {user?.email || "Career Pilot Pro"}
                    </p>
                  </div>
                </div>
              </DropdownMenuLabel>
              
              <DropdownMenuSeparator className="bg-border/40" />
              <DropdownMenuLabel className="px-4 py-2 text-xs uppercase tracking-[0.15em] font-semibold text-muted-foreground/70">
                Account
              </DropdownMenuLabel>
              <DropdownMenuItem asChild className="cursor-pointer rounded-lg p-3 transition-colors hover:bg-muted/50 focus:bg-muted">
                <Link href={getWorkspaceHref(workspaceBase, "settings/profile")}>
                  <UserCircle className="mr-3 h-4 w-4 text-primary/80" />
                  <span>Profile Settings</span>
                </Link>
              </DropdownMenuItem>

              <DropdownMenuSeparator className="bg-border/40 my-2" />
              <DropdownMenuLabel className="px-4 py-2 text-xs uppercase tracking-[0.15em] font-semibold text-muted-foreground/70">
                Workspace
              </DropdownMenuLabel>
              <DropdownMenuItem asChild className="cursor-pointer rounded-lg p-3 transition-colors hover:bg-muted/50 focus:bg-muted">
                <Link href={workspaceBase}>
                  <LayoutDashboard className="mr-3 h-4 w-4 text-primary/80" />
                  <span>Dashboard</span>
                </Link>
              </DropdownMenuItem>
              <DropdownMenuItem asChild className="cursor-pointer rounded-lg p-3 transition-colors hover:bg-muted/50 focus:bg-muted">
                <Link href={getWorkspaceHref(workspaceBase, "notifications")}>
                  <Bell className="mr-3 h-4 w-4 text-primary/80" />
                  <span>Notifications</span>
                </Link>
              </DropdownMenuItem>
              <DropdownMenuItem asChild className="cursor-pointer rounded-lg p-3 transition-colors hover:bg-muted/50 focus:bg-muted">
                <Link href={getWorkspaceHref(workspaceBase, "settings")}>
                  <Settings className="mr-3 h-4 w-4 text-primary/80" />
                  <span>Preferences</span>
                </Link>
              </DropdownMenuItem>

              <DropdownMenuItem asChild className="cursor-pointer rounded-lg p-3 transition-colors hover:bg-muted/50 focus:bg-muted lg:hidden">
                <Link href="/">
                  <Home className="mr-3 h-4 w-4 text-primary/80" />
                  <span>Public Site</span>
                </Link>
              </DropdownMenuItem>

              <div className="px-1 py-2">
                <ThemeModeToggle />
              </div>

              <DropdownMenuSeparator className="bg-border/40 my-2" />
              <DropdownMenuItem
                className="cursor-pointer rounded-lg p-3 text-destructive/80 transition-colors hover:bg-destructive/10 focus:bg-destructive/10 focus:text-destructive"
                onSelect={(event) => {
                  event.preventDefault();
                  void handleLogout();
                }}
              >
                <LogOut className="mr-3 h-4 w-4" />
                <span>Logout</span>
              </DropdownMenuItem>
            </DropdownMenuContent>
          </DropdownMenu>
        </div>
      </div>
    </header>
  );
}
