"use client";

import Link from "next/link";
import { usePathname, useRouter } from "next/navigation";
import { useEffect, useState } from "react";
import { motion } from "framer-motion";
import {
  LayoutDashboard,
  FileText,
  Map,
  MessageSquare,
  Briefcase,
  Settings,
  Bell,
  BarChart3,
  SearchCheck,
  UsersRound,
  ChevronLeft,
  ChevronRight,
  LogOut,
  UserCircle,
} from "lucide-react";
import { cn } from "@/shared/lib/utils";
import { Button } from "@/shared/components/ui/button";
import { useAuthStore } from "@/shared/store/auth-store";
import { authApi } from "@/services/auth/auth-api";
import {
  getRoleDashboardHref,
  getRoleWorkspaceLabel,
  getWorkspaceBaseFromPath,
  getWorkspaceHref,
} from "@/shared/lib/role-routing";

const navItems = [
  { icon: LayoutDashboard, label: "Dashboard", path: "" },
  {
    icon: FileText,
    label: "Resume Analysis",
    path: "resume",
  },
  { icon: Map, label: "Career Roadmap", path: "roadmap" },
  {
    icon: MessageSquare,
    label: "Interview Practice",
    path: "interview",
  },
  {
    icon: BarChart3,
    label: "Skill Analytics",
    path: "skills",
  },
  {
    icon: SearchCheck,
    label: "Job Matches",
    path: "jobs",
  },
  { icon: Briefcase, label: "AI Assistant", path: "chat" },
  { icon: UsersRound, label: "Mentor Center", path: "mentor" },
  { icon: Bell, label: "Notifications", path: "notifications" },
  { icon: Settings, label: "Settings", path: "settings" },
];

interface SidebarProps {
  isCollapsed: boolean;
  desktopWidth: number;
  onCollapseToggle: () => void;
  isMobileOpen: boolean;
  onMobileClose: () => void;
}

export function Sidebar({
  isCollapsed,
  desktopWidth,
  onCollapseToggle,
  isMobileOpen,
  onMobileClose,
}: SidebarProps) {
  const pathname = usePathname();
  const router = useRouter();
  const role = useAuthStore((state) => state.role);
  const user = useAuthStore((state) => state.user);
  const logout = useAuthStore((state) => state.logout);
  const workspaceBase = getWorkspaceBaseFromPath(pathname, role);
  const dashboardHref = getRoleDashboardHref(role);
  const workspaceLabel = getRoleWorkspaceLabel(role);
  const [activeHash, setActiveHash] = useState("");
  const resolvedNavItems = navItems.map((item) => ({
    ...item,
    href:
      item.path === "mentor" && (workspaceBase || dashboardHref) === "/dashboard/mentor"
        ? "/dashboard/mentor"
        : getWorkspaceHref(workspaceBase || dashboardHref, item.path),
  }));

  useEffect(() => {
    const syncHash = () => {
      setActiveHash(window.location.hash);
    };

    syncHash();
    window.addEventListener("hashchange", syncHash);
    return () => window.removeEventListener("hashchange", syncHash);
  }, [pathname]);

  const getIsActive = (href: string) => {
    const [hrefPath, hrefHash] = href.split("#");

    if (hrefHash) {
      return pathname === hrefPath && activeHash === `#${hrefHash}`;
    }

    if (activeHash) return false;

    return (
      pathname === hrefPath ||
      (hrefPath !== workspaceBase && pathname.startsWith(`${hrefPath}/`))
    );
  };

  const handleNavClick = (href: string) => {
    const [, hrefHash] = href.split("#");
    setActiveHash(hrefHash ? `#${hrefHash}` : "");
    onMobileClose();
  };

  const handleLogout = async () => {
    try {
      await authApi.logout();
    } finally {
      logout();
      onMobileClose();
      router.replace("/login");
    }
  };

  const renderContent = (showCollapseControl: boolean) => (
    <div className="relative flex h-full min-h-0 flex-col">
      <div className="flex h-16 shrink-0 items-center border-b border-border/70 px-5">
        <div className="flex min-w-0 items-center gap-3">
          <div className="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary shadow-sm shadow-primary/20">
            <span className="text-lg font-bold text-primary-foreground">C</span>
          </div>
          {!isCollapsed && (
            <span className="truncate text-lg font-semibold tracking-tight text-foreground">
              CareerAI
            </span>
          )}
        </div>
      </div>

      <nav className="custom-scrollbar min-h-0 flex-1 space-y-1 overflow-y-auto px-3 py-5">
        {resolvedNavItems.map((item) => {
          const isActive = getIsActive(item.href);

          return (
            <Link
              key={item.href}
              href={item.href}
              onClick={() => handleNavClick(item.href)}
            >
              <div
                className={cn(
                  "group relative flex items-center gap-3 rounded-lg px-3 py-2.5 transition-colors duration-200 focus-within:ring-2 focus-within:ring-ring/30",
                  isCollapsed ? "justify-center" : "",
                  isActive
                    ? "bg-primary/10 text-primary"
                    : "text-muted-foreground hover:bg-muted/55 hover:text-foreground",
                )}
              >
                {isActive && (
                  <motion.div
                    layoutId="active-pill-sidebar"
                    className="absolute left-0 top-1/2 h-7 w-1 -translate-y-1/2 rounded-r-full bg-primary"
                    transition={{
                      type: "spring",
                      stiffness: 300,
                      damping: 30,
                    }}
                  />
                )}
                <item.icon
                  className={cn(
                    "h-5 w-5 shrink-0 transition-colors",
                    isActive ? "text-primary" : "group-hover:text-foreground",
                  )}
                />
                {!isCollapsed && (
                  <span className="truncate text-sm font-medium leading-none">
                    {item.label}
                  </span>
                )}

                {isCollapsed && showCollapseControl && (
                  <div className="absolute left-full top-1/2 z-50 hidden -translate-y-1/2 rounded-lg border border-border bg-popover px-3 py-2 text-xs text-popover-foreground shadow-lg group-hover:block">
                    {item.label}
                  </div>
                )}
              </div>
            </Link>
          );
        })}
      </nav>

      <div className="shrink-0 border-t border-border/70 p-4">
        <div
          className={cn(
            "flex items-center gap-3 rounded-lg p-3 transition-colors duration-200",
            isCollapsed ? "justify-center" : "hover:bg-muted/55",
          )}
        >
          <div className="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-primary/20 bg-primary/10">
            <UserCircle className="h-6 w-6 text-primary" />
          </div>
          {!isCollapsed && (
            <div className="min-w-0 flex-1">
              <p className="truncate text-sm font-semibold text-foreground">
                {user?.name || "CareerAI User"}
              </p>
              <p className="text-xs text-muted-foreground">{workspaceLabel}</p>
            </div>
          )}
        </div>

        <Button
          variant="ghost"
          onClick={() => void handleLogout()}
          className={cn(
            "mt-3 h-10 w-full justify-start gap-3 rounded-lg text-muted-foreground hover:bg-muted/55 hover:text-foreground",
            isCollapsed ? "justify-center px-0" : "",
          )}
        >
          <LogOut className="h-4 w-4" />
          {!isCollapsed && (
            <span className="text-sm font-medium">Sign out</span>
          )}
        </Button>
      </div>

      {showCollapseControl && (
        <button
          onClick={onCollapseToggle}
          className="absolute -right-3 top-5 z-50 flex h-8 w-8 items-center justify-center rounded-full border border-border bg-card shadow-sm transition-all hover:bg-muted/70 focus:outline-none focus:ring-2 focus:ring-ring/40"
          aria-label={isCollapsed ? "Expand sidebar" : "Collapse sidebar"}
        >
          {isCollapsed ? (
            <ChevronRight className="h-4 w-4" />
          ) : (
            <ChevronLeft className="h-4 w-4" />
          )}
        </button>
      )}
    </div>
  );

  return (
    <>
      <motion.aside
        initial={false}
        animate={{ width: desktopWidth }}
        style={{ width: desktopWidth }}
        className="dark-surface-sidebar relative z-40 hidden h-full min-h-0 shrink-0 flex-col border-r border-border/80 bg-card shadow-xl shadow-elevation/10 md:flex dark:border-border/70"
      >
        {renderContent(true)}
      </motion.aside>

      <div
        className={cn(
          "fixed inset-0 z-50 transition-all duration-300 md:hidden",
          isMobileOpen
            ? "visible opacity-100"
            : "invisible pointer-events-none opacity-0",
        )}
      >
        <div
          className="absolute inset-0 bg-muted/60 backdrop-blur-sm"
          onClick={onMobileClose}
        />
        <aside className="dark-surface-sidebar relative flex h-dvh w-80 max-w-[85vw] flex-col overflow-hidden border-r border-border bg-card shadow-xl shadow-elevation/25 dark:border-border/70">
          {renderContent(false)}
        </aside>
      </div>
    </>
  );
}
